# ============================================================
# Trenchcord Backend (.env)
# Deploy on: VPS
# ============================================================
# LOCAL MODE: No .env needed, just "npm run dev".
# HOSTED MODE: Copy to .env and fill in values.
# ============================================================

# "local" = self-hosted single user (no config needed)
# "hosted" = multi-user web app with Supabase
TRENCHCORD_MODE=local

# Server port (defaults to 3001)
# PORT=3001

# --- Everything below: ONLY for hosted mode ---
    
# Supabase (dashboard > Settings > API)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=your-service-role-key

# AES-256 encryption key for Discord tokens at rest
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# TOKEN_ENCRYPTION_KEY=

# CORS — your Netlify frontend URL (comma-separated if multiple)
# ALLOWED_ORIGINS=https://app.trenchcord.app
