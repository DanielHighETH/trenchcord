# ============================================================
# Trenchcord Frontend (.env)
# Deploy on: Netlify (set these in Netlify dashboard > Site
# settings > Environment variables for production)
# ============================================================
# LOCAL MODE: No config needed, just "npm run dev:frontend".
# HOSTED MODE: Set these vars in your Netlify build env.
# ============================================================

# Demo mode (landing page demo, unrelated to hosted mode)
VITE_DEMO_MODE=false

# --- Everything below: ONLY for hosted mode ---

# Backend API URL (your VPS where the backend runs)
# VITE_API_URL=https://api.trenchcord.app

# Supabase (dashboard > Settings > API — anon key only, NEVER service_role)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
